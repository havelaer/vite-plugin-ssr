{
  "name": "@havelaer/vite-plugin-ssr",
  "version": "0.0.14",
  "description": "SSR plugin for Vite. With optional API servers.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/havelaer/vite-plugin-ssr.git"
  },
  "exports": {
    ".": {
      "import": "./dist/plugin.mjs",
      "types": "./dist/plugin.d.mts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "tsdown src/plugin.ts --dts --watch ./src",
    "check": "biome check .",
    "release": "npm run check && tsc && npm version patch -m 'chore: bump version %s'",
    "postrelease": "git push && git push --tags",
    "build": "tsdown src/plugin.ts --dts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "vite",
    "ssr"
  ],
  "author": "Havelaer",
  "license": "MIT",
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "workspaces": [
    ".",
    "examples/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "cheerio": "^1.2.0"
  }
}
